# Copy to .env and fill in values. Never commit .env.

# Django
SECRET_KEY=replace-with-a-strong-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Logging
LOG_LEVEL=INFO

# REST API authentication (comma-separated label:key pairs)
DAYFRAME_API_KEYS=internal:replace-with-32-byte-random-key
API_MAX_CONCURRENT_JOBS=4
API_THROTTLE_SUBMIT=60/min
API_THROTTLE_STATUS=600/min
API_THROTTLE_RESULT=120/min
API_THROTTLE_CANCEL=60/min
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760

# Media / static
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# Optional: detailed support constraint logging in optimizer
DEBUG_SUPPORT=0

# Database (uses SQLite by default)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
